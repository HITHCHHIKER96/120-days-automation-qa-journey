# Exercise 1: Rectangle Area Calculator:

length = int(input("Enter the length: "))
width = int(input("Enter the width: "))

Area = (length * width)
print(f"The area of rectangle is: {Area}cm²")

# Exercise 2: Shopping Cart Program:

items = input("What would u like to buy?: ")
price = float(input("In what price do you want?: "))
quantity = int(input("How many do you want?: "))

total = (price * quantity)

print(f"You have ordered {quantity} {items}/s")
print(f"Your bill is ${total}")



